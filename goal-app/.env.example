# Variables de entorno para GoalApp Mobile
# Copia este archivo a .env y configura tus variables

# API URLs
EXPO_PUBLIC_API_URL_DEV=http://localhost:8000/api/v1
EXPO_PUBLIC_API_URL_PROD=https://goalapp-backend-j2cx.onrender.com/api/v1

# Feature flags
EXPO_PUBLIC_USE_MOCKS=false
EXPO_PUBLIC_ENABLE_LOGS=false

# Timeouts (segundos)
EXPO_PUBLIC_REQUEST_TIMEOUT=30
EXPO_PUBLIC_MAX_RETRIES=3
